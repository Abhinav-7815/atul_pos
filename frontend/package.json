{
  "name": "atul-pos",
  "private": true,
  "version": "1.0.0",
  "description": "Professional POS System for Atul Ice Cream",
  "author": "Atul Ice Cream",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "node_modules/electron/dist/electron.exe .",
    "electron:build": "electron-builder"
  },
  "build": {
    "appId": "com.atulicecream.pos",
    "productName": "Atul Ice Cream POS",
    "directories": {
      "output": "dist_electron2"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "print_server.py"
    ],
    "extraResources": [
      {
        "from": "print_server_dist/print_server.exe",
        "to": "print_server.exe"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Atul POS"
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.0",
    "sweetalert2": "^11.26.24",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
